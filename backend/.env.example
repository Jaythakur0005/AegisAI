# ============================================================
# AegisAI Backend — Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit the actual `.env` file.
# ============================================================

# ---------------- Application ----------------
APP_NAME=AegisAI
APP_ENV=development          # development | staging | production
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# ---------------- Server ----------------
HOST=0.0.0.0
PORT=8000

# ---------------- CORS ----------------
# Comma-separated list of allowed origins (e.g. React dev server)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------- MongoDB ----------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=aegisai
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# ---------------- OpenAI (Investigation Engine) ----------------
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1500
OPENAI_TEMPERATURE=0.2
OPENAI_REQUEST_TIMEOUT_SECONDS=60

# ---------------- ML Model Artifacts ----------------
MODEL_ARTIFACTS_DIR=./model_artifacts
AUTOENCODER_MODEL_PATH=./model_artifacts/autoencoder.keras
FEATURE_SCALER_PATH=./model_artifacts/scaler.pkl
MODEL_VERSION=v1.0.0

# ---------------- Anomaly Detection Thresholds ----------------
# Percentile of training reconstruction error used as the anomaly cutoff
ANOMALY_THRESHOLD_PERCENTILE=95
ANOMALY_THRESHOLD_VALUE=
# (If ANOMALY_THRESHOLD_VALUE is set, it overrides the percentile-derived threshold)

# ---------------- Incident Timeline Builder ----------------
INCIDENT_WINDOW_MINUTES=20

# ---------------- MITRE ATT&CK Local Cache ----------------
MITRE_LOOKUP_PATH=./app/core/mitre/attack_lookup.json

# ---------------- Risk Scoring Weights ----------------
RISK_WEIGHT_ANOMALY=0.4
RISK_WEIGHT_TECHNIQUE_SEVERITY=0.4
RISK_WEIGHT_ASSET_CRITICALITY=0.2

# ---------------- Logging ----------------
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                # json | text
LOG_FILE_PATH=./logs/aegisai.log
LOG_TO_CONSOLE=true
LOG_TO_FILE=false