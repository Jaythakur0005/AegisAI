"""
Feature engineering service.

Implements Stage 2 (Feature Engineering) from ARCHITECTURE_V2.md: reads
raw Sysmon event records from the `raw_logs` collection, groups them by
host and time window, extracts numerical feature vectors per window, and
persists the result as `ProcessedEvent` documents into `processed_events`,
linked back to their source `raw_logs` via `raw_log_ref`.

ARCHITECTURE_V2.md Stage 2 names six feature categories without
specifying exact formulas or window size. This module makes the
following concrete (and documented) choices to operationalize them:

    - Window size: defaults to the architecture's incident-window scale
      (configurable via `Settings.incident_window_minutes`), since no
      separate feature-engineering window size is specified in the
      architecture doc. Events are grouped by (host, window) where
      window = floor(event.timestamp to the window boundary).
    - Sysmon Event ID mapping (per Stage 2's "Event ID 1/3/7/11/13"
      reference):
        1  -> process creation
        3  -> network connection
        7  -> image loaded (not separately featurized; reserved)
        11 -> file create (used for file write pattern proxy)
        13 -> registry value set (used for registry write pattern proxy)
    - Command-line entropy: standard Shannon entropy (base 2) over the
      character distribution of each process-creation event's
      `CommandLine` field, averaged per window.
    - Time-of-day buckets: 4 fixed 6-hour buckets (night/morning/
      afternoon/evening), one-hot encoded, based on `window_start`.
    - Parent-child process anomaly: a window-level count of process
      creation events whose parent image differs from a small,
      hardcoded set of expected Windows parent processes (explorer.exe,
      services.exe, svchost.exe, cmd.exe, powershell.exe) — a simple,
      auditable heuristic consistent with Stage 2's "rule-assisted,
      not purely model-derived" philosophy used elsewhere in the
      architecture (e.g. MITRE mapping).

This module reads from and writes to MongoDB directly via
`app.db.mongo_client.get_database()`, consistent with the precedent set
in `app.services.log_ingestion` (no repository layer exists yet for
`raw_logs`/`processed_events`).
"""

from __future__ import annotations

import math
from collections import Counter, defaultdict
from dataclasses import dataclass, field
from datetime import datetime, timedelta, timezone
from typing import Any, Dict, List, Sequence

from pymongo.errors import PyMongoError

from app.core.config import get_settings
from app.core.logging import get_logger
from app.db.mongo_client import get_database
from app.models.processed_event import ProcessedEvent
from app.models.raw_log import RawLog

logger = get_logger(__name__)

_RAW_LOGS_COLLECTION = "raw_logs"
_PROCESSED_EVENTS_COLLECTION = "processed_events"

# Sysmon Event IDs referenced by Stage 2 of ARCHITECTURE_V2.md.
_EVENT_ID_PROCESS_CREATION = 1
_EVENT_ID_NETWORK_CONNECTION = 3
_EVENT_ID_FILE_CREATE = 11
_EVENT_ID_REGISTRY_SET = 13

# Expected/benign parent process images for the parent-child anomaly
# heuristic. Anything else spawning a child process counts as a
# parent-child anomaly for that window. Kept as a small, explicit,
# auditable set rather than a learned model, consistent with the
# architecture's "rule-assisted, grounded" philosophy used for MITRE
# mapping.
_EXPECTED_PARENT_IMAGES: frozenset[str] = frozenset(
    {
        "explorer.exe",
        "services.exe",
        "svchost.exe",
        "cmd.exe",
        "powershell.exe",
    }
)

# Fixed 6-hour time-of-day buckets, one-hot encoded in this order.
_TIME_OF_DAY_BUCKETS: tuple[str, ...] = (
    "night",       # 00:00-05:59
    "morning",     # 06:00-11:59
    "afternoon",   # 12:00-17:59
    "evening",     # 18:00-23:59
)

# Canonical, ordered feature names. This order defines the positional
# contract of every `feature_vector` this module produces, and must
# stay in sync with `_build_feature_vector`.
FEATURE_NAMES: tuple[str, ...] = (
    "process_creation_frequency",
    "parent_child_process_anomalies",
    "network_connection_count",
    "registry_file_write_count",
    "command_line_entropy_mean",
    "time_of_day_night",
    "time_of_day_morning",
    "time_of_day_afternoon",
    "time_of_day_evening",
)


class FeatureEngineeringError(RuntimeError):
    """
    Raised for failures that prevent feature engineering from
    proceeding at all (e.g. the database is unreachable), as distinct
    from a single malformed raw_log document, which is skipped and
    logged rather than raised.
    """


@dataclass
class FeatureEngineeringResult:
    """
    Outcome of a feature-engineering run.

    `inserted_ids` holds the Mongo `_id` of every `ProcessedEvent`
    successfully written to `processed_events`. `skipped_raw_logs`
    records any raw_logs documents that could not be grouped/featurized
    (e.g. missing/malformed fields), each with a reason, without
    aborting the rest of the run.
    """

    inserted_ids: List[str] = field(default_factory=list)
    skipped_raw_logs: List[Dict[str, Any]] = field(default_factory=list)

    @property
    def windows_processed(self) -> int:
        """Number of (host, window) groups that produced a ProcessedEvent."""
        return len(self.inserted_ids)


def _floor_to_window(timestamp: datetime, window_minutes: int) -> datetime:
    """
    Floor a UTC timestamp to the start of its enclosing fixed window.

    Windows are anchored to the start of the day (00:00 UTC) in
    increments of `window_minutes`, so windows are deterministic and
    reproducible across runs rather than dependent on the order events
    are processed in.
    """
    if timestamp.tzinfo is None:
        timestamp = timestamp.replace(tzinfo=timezone.utc)

    day_start = timestamp.replace(hour=0, minute=0, second=0, microsecond=0)
    elapsed_minutes = (timestamp - day_start).total_seconds() / 60.0
    window_index = int(elapsed_minutes // window_minutes)
    return day_start + timedelta(minutes=window_index * window_minutes)


def _shannon_entropy(text: str) -> float:
    """
    Compute the Shannon entropy (base 2) of a string's character
    distribution.

    Returns 0.0 for an empty string. Used as a proxy signal for
    obfuscated/encoded command lines (e.g. base64-encoded PowerShell),
    which tend to have higher entropy than typical plaintext commands.
    """
    if not text:
        return 0.0

    counts = Counter(text)
    length = len(text)
    entropy = 0.0
    for count in counts.values():
        probability = count / length
        entropy -= probability * math.log2(probability)
    return entropy


def _time_of_day_bucket_index(timestamp: datetime) -> int:
    """Return the index (0-3) of the 6-hour time-of-day bucket for `timestamp`."""
    return min(timestamp.hour // 6, len(_TIME_OF_DAY_BUCKETS) - 1)


def _extract_event_field(raw_event: Dict[str, Any], *candidates: str) -> str:
    """
    Look up a value from a raw Sysmon event payload by trying several
    possible key names, since field casing/naming can vary slightly
    between exporters (e.g. 'Image' vs 'image', 'ParentImage' vs
    'parent_image').

    Returns an empty string if none of the candidate keys are present,
    rather than raising — a missing optional field should degrade the
    relevant feature, not abort the whole window.
    """
    for key in candidates:
        if key in raw_event and raw_event[key] is not None:
            return str(raw_event[key])
    return ""


async def _fetch_raw_logs(window_minutes: int) -> List[RawLog]:
    """
    Fetch raw_logs whose host/time window has not already produced
    a ProcessedEvent.

    A ProcessedEvent represents an entire window, so raw_log_ref alone
    cannot be used to determine whether all events in that window were
    already processed.
    """
    db = get_database()

    try:
        processed_windows = {
            (
                str(document["host"]),
                document["window_start"],
            )
            async for document in db[_PROCESSED_EVENTS_COLLECTION].find(
                {},
                {
                    "host": 1,
                    "window_start": 1,
                },
            )
            if document.get("host") is not None
            and document.get("window_start") is not None
        }
    except PyMongoError as exc:
        logger.exception("Failed to fetch existing processed windows")
        raise FeatureEngineeringError(
            f"Failed to query processed_events: {exc}"
        ) from exc

    raw_logs: List[RawLog] = []

    try:
        cursor = db[_RAW_LOGS_COLLECTION].find({})

        async for document in cursor:
            try:
                raw_log = RawLog(**document)

                window_start = _floor_to_window(
                    raw_log.timestamp,
                    window_minutes,
                )

                window_key = (
                    raw_log.host,
                    window_start,
                )

                if window_key in processed_windows:
                    continue

                raw_logs.append(raw_log)

            except Exception:  # noqa: BLE001
                logger.warning(
                    "Skipping malformed raw_logs document",
                    extra={
                        "raw_log_id": str(document.get("_id"))
                    },
                )

    except PyMongoError as exc:
        logger.exception("Failed to fetch raw_logs documents")
        raise FeatureEngineeringError(
            f"Failed to query raw_logs: {exc}"
        ) from exc

    logger.info(
        "Fetched unprocessed raw_logs",
        extra={"count": len(raw_logs)},
    )

    return raw_logs

def _group_by_host_and_window(
    raw_logs: Sequence[RawLog], window_minutes: int
) -> Dict[tuple[str, datetime], List[RawLog]]:
    """Group RawLog records by (host, window_start) per the configured window size."""
    groups: Dict[tuple[str, datetime], List[RawLog]] = defaultdict(list)
    for raw_log in raw_logs:
        window_start = _floor_to_window(raw_log.timestamp, window_minutes)
        groups[(raw_log.host, window_start)].append(raw_log)
    return groups


def _build_feature_vector(
    window_raw_logs: Sequence[RawLog], window_start: datetime
) -> List[float]:
    """
    Compute the ordered feature vector for one (host, window) group.

    The returned list's positions correspond exactly to `FEATURE_NAMES`.
    """
    process_creation_count = 0
    parent_child_anomaly_count = 0
    network_connection_count = 0
    registry_file_write_count = 0
    command_line_entropies: List[float] = []

    for raw_log in window_raw_logs:
        raw_event = raw_log.raw_event

        if raw_log.event_id == _EVENT_ID_PROCESS_CREATION:
            process_creation_count += 1

            command_line = _extract_event_field(
                raw_event, "CommandLine", "command_line"
            )
            command_line_entropies.append(_shannon_entropy(command_line))

            parent_image = _extract_event_field(
                raw_event, "ParentImage", "parent_image"
            ).lower()
            parent_basename = parent_image.rsplit("\\", maxsplit=1)[-1]
            if parent_basename and parent_basename not in _EXPECTED_PARENT_IMAGES:
                parent_child_anomaly_count += 1

        elif raw_log.event_id == _EVENT_ID_NETWORK_CONNECTION:
            network_connection_count += 1

        elif raw_log.event_id in (
            _EVENT_ID_FILE_CREATE,
            _EVENT_ID_REGISTRY_SET,
        ):
            registry_file_write_count += 1

    command_line_entropy_mean = (
        sum(command_line_entropies) / len(command_line_entropies)
        if command_line_entropies
        else 0.0
    )

    time_of_day_one_hot = [0.0] * len(_TIME_OF_DAY_BUCKETS)
    time_of_day_one_hot[_time_of_day_bucket_index(window_start)] = 1.0

    return [
        float(process_creation_count),
        float(parent_child_anomaly_count),
        float(network_connection_count),
        float(registry_file_write_count),
        command_line_entropy_mean,
        *time_of_day_one_hot,
    ]


async def _insert_processed_events(
    processed_events: List[ProcessedEvent],
) -> List[str]:
    """
    Persist a list of `ProcessedEvent` instances into `processed_events`.

    Raises:
        FeatureEngineeringError: If the insert operation fails.
    """
    if not processed_events:
        return []

    db = get_database()
    documents = [
        processed_event.model_dump(by_alias=True, exclude={"id"})
        for processed_event in processed_events
    ]

    try:
        if len(documents) == 1:
            result = await db[_PROCESSED_EVENTS_COLLECTION].insert_one(
                documents[0]
            )
            inserted_ids = [str(result.inserted_id)]
        else:
            result = await db[_PROCESSED_EVENTS_COLLECTION].insert_many(
                documents, ordered=False
            )
            inserted_ids = [str(_id) for _id in result.inserted_ids]
    except PyMongoError as exc:
        logger.exception(
            "Failed to insert processed_events documents",
            extra={"attempted_count": len(documents)},
        )
        raise FeatureEngineeringError(
            f"Failed to persist {len(documents)} processed_events "
            f"document(s): {exc}"
        ) from exc

    logger.info(
        "Inserted processed_events documents",
        extra={"inserted_count": len(inserted_ids)},
    )
    return inserted_ids


async def run_feature_engineering() -> FeatureEngineeringResult:
    """
    Run Stage 2 (Feature Engineering) end-to-end.

    Fetches all `raw_logs` documents not yet linked to a
    `processed_events` document, groups them by host and time window,
    extracts the six documented feature categories per window, and
    persists the resulting `ProcessedEvent` documents.

    Each (host, window) group is linked back to its raw_logs source via
    `ProcessedEvent.raw_log_ref`, set to the most recent raw_log in that
    window (the reference field models a single source document per
    the existing schema; the full set of contributing raw_logs for a
    window is recoverable by re-querying raw_logs for the same host and
    window range if needed).

    Returns:
        A `FeatureEngineeringResult` summarizing every ProcessedEvent
        inserted and every raw_logs document skipped.

    Raises:
        FeatureEngineeringError: If fetching raw_logs or persisting
            processed_events fails at the infrastructure level.
    """
    settings = get_settings()
    window_minutes = settings.incident_window_minutes

    logger.info(
        "Starting feature engineering run",
        extra={"window_minutes": window_minutes},
    )

    result = FeatureEngineeringResult()
    raw_logs = await _fetch_raw_logs(window_minutes)

    if not raw_logs:
        logger.info("No unprocessed raw_logs found; nothing to featurize")
        return result

    grouped = _group_by_host_and_window(raw_logs, window_minutes)
    logger.info("Grouped raw_logs into windows", extra={"window_count": len(grouped)})

    processed_events: List[ProcessedEvent] = []

    for (host, window_start), window_raw_logs in grouped.items():
        window_end = window_start + timedelta(minutes=window_minutes)
        try:
            feature_vector = _build_feature_vector(window_raw_logs, window_start)
            most_recent_raw_log = max(window_raw_logs, key=lambda r: r.timestamp)

            processed_event = ProcessedEvent(
                raw_log_ref=most_recent_raw_log.id,
                host=host,
                window_start=window_start,
                window_end=window_end,
                feature_vector=feature_vector,
                feature_names=list(FEATURE_NAMES),
            )
            processed_events.append(processed_event)
        except Exception:  # noqa: BLE001 - isolate one bad window
            logger.exception(
                "Failed to build feature vector for window",
                extra={"host": host, "window_start": window_start.isoformat()},
            )
            result.skipped_raw_logs.append(
                {
                    "host": host,
                    "window_start": window_start.isoformat(),
                    "reason": "Feature vector construction failed",
                    "raw_log_count": len(window_raw_logs),
                }
            )

    inserted_ids = await _insert_processed_events(processed_events)
    result.inserted_ids.extend(inserted_ids)

    logger.info(
        "Completed feature engineering run",
        extra={
            "windows_processed": result.windows_processed,
            "windows_skipped": len(result.skipped_raw_logs),
        },
    )
    return result