"""
Incident builder service.

Implements Stage 4 (Incident Timeline Builder) from ARCHITECTURE_V2.md:
reads anomalous events from the `anomalies` collection, groups them by
host and time-window (per `Settings.incident_window_minutes`), orders
each group into a chronological event sequence, and persists the
result as `Incident` documents into the `incidents` collection.

Per Stage 4's description ("Anomalous events grouped by host +
time-window... and correlated by process lineage"), grouping here is
host + time-window based; process-lineage correlation is not performed
in this module since `Anomaly` documents (this module's sole input,
per task scope) do not carry process-lineage fields — those live on
`processed_events`/`raw_logs`, which this module does not read. See
the "Architectural notes" section at the bottom of this docstring.

Incident severity: the existing `Incident` schema (`app/models/
incident.py`) has no field to persist a severity rating — its only
fields are host, start_time, end_time, event_sequence, status, and
created_at. Since modifying that schema is out of scope, this module
computes a severity rating from the constituent anomalies'
reconstruction errors (satisfying the task's "calculate incident
severity" requirement) and surfaces it via structured logging only,
NOT as a persisted field on the Incident document. Callers that need
the severity value programmatically should call
`compute_incident_severity` directly rather than reading it back from
a persisted Incident.

This module reads from and writes to MongoDB directly via
`app.db.mongo_client.get_database()`, consistent with the precedent set
by `app.services.log_ingestion`, `app.services.feature_engineering`,
`app.services.anomaly_detector`, and `app.services.mitre_mapper` (no
repository layer exists yet for `anomalies`/`incidents`).

Architectural notes / scope boundaries:
    - "Skip anomalies already assigned to incidents" is implemented by
      excluding any anomaly `_id` already present in some existing
      Incident's `event_sequence` array.
    - Grouping windows are anchored deterministically (floored to
      `incident_window_minutes` boundaries from the start of the day,
      UTC), the same anchoring strategy used in
      `app.services.feature_engineering`, so repeated runs group
      anomalies consistently rather than depending on processing
      order.
    - Each (host, window) group with at least one anomaly produces
      exactly one Incident document.
"""

from __future__ import annotations

from dataclasses import dataclass, field
from datetime import datetime, timedelta, timezone
from enum import Enum
from typing import Any, Dict, List, Sequence

from pymongo.errors import PyMongoError

from app.core.config import get_settings
from app.core.logging import get_logger
from app.db.mongo_client import get_database
from app.models.anomaly import Anomaly
from app.models.incident import Incident, IncidentStatus

logger = get_logger(__name__)

_ANOMALIES_COLLECTION = "anomalies"
_PROCESSED_EVENTS_COLLECTION = "processed_events"
_INCIDENTS_COLLECTION = "incidents"


class IncidentSeverity(str, Enum):
    """
    Severity rating derived from an incident's constituent anomalies.

    Not persisted on the `Incident` model (see module docstring) —
    used only for logging/audit and as the return value of
    `compute_incident_severity` for callers that need it
    programmatically (e.g. a future risk-scoring module).
    """

    LOW = "Low"
    MEDIUM = "Medium"
    HIGH = "High"
    CRITICAL = "Critical"


class IncidentBuilderError(RuntimeError):
    """
    Raised for failures that prevent incident building from proceeding
    at all (e.g. the database is unreachable), as distinct from a
    single malformed anomaly document, which is skipped and logged
    rather than raised.
    """


@dataclass
class IncidentBuilderResult:
    """
    Outcome of an incident-building run.

    `inserted_ids` holds the Mongo `_id` of every `Incident` document
    successfully written. `skipped_groups` records any (host, window)
    groups that could not be built into an Incident, each with a
    reason, without aborting the rest of the run.
    """

    inserted_ids: List[str] = field(default_factory=list)
    skipped_groups: List[Dict[str, Any]] = field(default_factory=list)

    @property
    def incidents_created(self) -> int:
        """Number of Incident documents successfully persisted."""
        return len(self.inserted_ids)


def _floor_to_window(timestamp: datetime, window_minutes: int) -> datetime:
    """
    Floor a UTC timestamp to the start of its enclosing fixed window.

    Windows are anchored to the start of the day (00:00 UTC) in
    increments of `window_minutes`, mirroring the anchoring strategy in
    `app.services.feature_engineering`, so grouping is deterministic
    and reproducible across runs rather than dependent on processing
    order.
    """
    if timestamp.tzinfo is None:
        timestamp = timestamp.replace(tzinfo=timezone.utc)

    day_start = timestamp.replace(hour=0, minute=0, second=0, microsecond=0)
    elapsed_minutes = (timestamp - day_start).total_seconds() / 60.0
    window_index = int(elapsed_minutes // window_minutes)
    return day_start + timedelta(minutes=window_index * window_minutes)


def compute_incident_severity(anomalies: Sequence[Anomaly]) -> IncidentSeverity:
    """
    Derive a severity rating for a group of anomalies that will form
    one incident.

    Uses the maximum ratio of `reconstruction_error` to
    `threshold_used` across the group as the severity signal — an
    anomaly that exceeds its threshold by a wide margin indicates a
    more severe deviation from benign behavior than one that barely
    crosses it. Banding follows the same quartile-style approach used
    elsewhere in the architecture (e.g. `RiskScore`'s banding),
    adapted to this module's own scale since no specific banding is
    defined for this metric in ARCHITECTURE_V2.md.

    Bands (max reconstruction_error / threshold_used ratio):
        < 1.5  -> Low
        < 2.5  -> Medium
        < 4.0  -> High
        >= 4.0 -> Critical

    Args:
        anomalies: The anomalies that constitute one incident. Must be
            non-empty.

    Returns:
        The derived `IncidentSeverity`.

    Raises:
        ValueError: If `anomalies` is empty.
    """
    if not anomalies:
        raise ValueError("Cannot compute severity for an empty anomaly group")

    max_ratio = max(
        (
            anomaly.reconstruction_error / anomaly.threshold_used
            if anomaly.threshold_used > 0
            else float("inf")
        )
        for anomaly in anomalies
    )

    if max_ratio < 1.5:
        return IncidentSeverity.LOW
    if max_ratio < 2.5:
        return IncidentSeverity.MEDIUM
    if max_ratio < 4.0:
        return IncidentSeverity.HIGH
    return IncidentSeverity.CRITICAL


async def _fetch_unassigned_anomalies() -> List[Anomaly]:
    """
    Fetch all `anomalies` documents flagged `is_anomalous=True` that
    are not yet referenced in any existing `Incident.event_sequence`,
    parsed into `Anomaly` instances.

    Malformed documents (failing `Anomaly` validation) are logged and
    skipped individually rather than aborting the fetch.

    Raises:
        IncidentBuilderError: If querying MongoDB fails.
    """
    db = get_database()

    try:
        already_assigned_refs: set[Any] = set()
        async for document in db[_INCIDENTS_COLLECTION].find(
            {}, {"event_sequence": 1}
        ):
            already_assigned_refs.update(document.get("event_sequence", []))
    except PyMongoError as exc:
        logger.exception("Failed to fetch existing incidents event_sequence refs")
        raise IncidentBuilderError(
            f"Failed to query incidents: {exc}"
        ) from exc

    anomalies: List[Anomaly] = []
    try:
        cursor = db[_ANOMALIES_COLLECTION].find({"is_anomalous": True})
        async for document in cursor:
            if document.get("_id") in already_assigned_refs:
                continue
            try:
                anomalies.append(Anomaly(**document))
            except Exception:  # noqa: BLE001 - isolate one bad document
                logger.warning(
                    "Skipping malformed anomalies document",
                    extra={"anomaly_id": str(document.get("_id"))},
                )
    except PyMongoError as exc:
        logger.exception("Failed to fetch anomalies documents")
        raise IncidentBuilderError(
            f"Failed to query anomalies: {exc}"
        ) from exc

    logger.info(
        "Fetched unassigned anomalous events", extra={"count": len(anomalies)}
    )
    return anomalies


async def _resolve_anomaly_event_windows(
    anomalies: Sequence[Anomaly],
) -> Dict[Any, tuple[datetime, datetime]]:
    """
    Resolve each anomaly to the source processed-event window.

    `Anomaly.detected_at` is inference time. Stage 4 correlation must use
    the original behavioural window represented by `feature_ref`.
    """
    if not anomalies:
        return {}

    db = get_database()
    feature_refs = [anomaly.feature_ref for anomaly in anomalies]

    event_windows: Dict[Any, tuple[datetime, datetime]] = {}

    try:
        cursor = db[_PROCESSED_EVENTS_COLLECTION].find(
            {"_id": {"$in": feature_refs}},
            {
                "_id": 1,
                "window_start": 1,
                "window_end": 1,
            },
        )

        async for document in cursor:
            window_start = document.get("window_start")
            window_end = document.get("window_end")

            if not isinstance(window_start, datetime):
                continue

            if not isinstance(window_end, datetime):
                continue

            if window_start.tzinfo is None:
                window_start = window_start.replace(tzinfo=timezone.utc)

            if window_end.tzinfo is None:
                window_end = window_end.replace(tzinfo=timezone.utc)

            event_windows[document["_id"]] = (
                window_start,
                window_end,
            )

    except PyMongoError as exc:
        logger.exception(
            "Failed to resolve anomaly processed-event windows"
        )
        raise IncidentBuilderError(
            f"Failed to query processed_events: {exc}"
        ) from exc

    return event_windows


def _group_by_host_and_window(
    anomalies: Sequence[Anomaly],
    event_windows: Dict[Any, tuple[datetime, datetime]],
    window_minutes: int,
) -> Dict[tuple[str, datetime], List[Anomaly]]:
    """
    Group anomalies by host and original security-event time.
    """
    groups: Dict[tuple[str, datetime], List[Anomaly]] = {}

    for anomaly in anomalies:
        event_window = event_windows.get(anomaly.feature_ref)

        if event_window is None:
            logger.warning(
                "Skipping anomaly with unresolved feature_ref",
                extra={
                    "anomaly_id": str(anomaly.id),
                    "feature_ref": str(anomaly.feature_ref),
                },
            )
            continue

        event_time = event_window[0]
        window_start = _floor_to_window(
            event_time,
            window_minutes,
        )

        key = (anomaly.host, window_start)
        groups.setdefault(key, []).append(anomaly)

    return groups


def _build_incident(
    host: str,
    anomalies: Sequence[Anomaly],
    event_windows: Dict[Any, tuple[datetime, datetime]],
) -> Incident:
    """
    Build an incident ordered by original processed-event window time.
    """
    if not anomalies:
        raise ValueError(
            "Cannot build an Incident from an empty anomaly group"
        )

    unresolved = [
        anomaly
        for anomaly in anomalies
        if anomaly.feature_ref not in event_windows
    ]

    if unresolved:
        raise ValueError(
            "Cannot build Incident with unresolved feature_ref values"
        )

    ordered_anomalies = sorted(
        anomalies,
        key=lambda anomaly: event_windows[
            anomaly.feature_ref
        ][0],
    )

    start_time = min(
        event_windows[anomaly.feature_ref][0]
        for anomaly in ordered_anomalies
    )

    end_time = max(
        event_windows[anomaly.feature_ref][1]
        for anomaly in ordered_anomalies
    )

    event_sequence = [
        anomaly.id
        for anomaly in ordered_anomalies
    ]

    return Incident(
        host=host,
        start_time=start_time,
        end_time=end_time,
        event_sequence=event_sequence,
        status=IncidentStatus.NEW,
        created_at=datetime.now(timezone.utc),
    )


async def _insert_incidents(incidents: List[Incident]) -> List[str]:
    """
    Persist a list of `Incident` instances into `incidents`.

    Raises:
        IncidentBuilderError: If the insert operation fails.
    """
    if not incidents:
        return []

    db = get_database()
    documents = [
        incident.model_dump(by_alias=True, exclude={"id"}) for incident in incidents
    ]

    try:
        if len(documents) == 1:
            result = await db[_INCIDENTS_COLLECTION].insert_one(documents[0])
            inserted_ids = [str(result.inserted_id)]
        else:
            result = await db[_INCIDENTS_COLLECTION].insert_many(
                documents, ordered=False
            )
            inserted_ids = [str(_id) for _id in result.inserted_ids]
    except PyMongoError as exc:
        logger.exception(
            "Failed to insert incidents documents",
            extra={"attempted_count": len(documents)},
        )
        raise IncidentBuilderError(
            f"Failed to persist {len(documents)} incidents document(s): {exc}"
        ) from exc

    logger.info(
        "Inserted incidents documents", extra={"inserted_count": len(inserted_ids)}
    )
    return inserted_ids


async def run_incident_building() -> IncidentBuilderResult:
    """
    Run Stage 4 (Incident Timeline Builder) end-to-end.

    Fetches all anomalous `anomalies` documents not yet assigned to an
    existing incident, groups them by host and time window, builds a
    chronological `Incident` for each non-empty group, computes and
    logs a severity rating per incident (see module docstring on why
    severity is not persisted), and persists the resulting `Incident`
    documents.

    Returns:
        An `IncidentBuilderResult` summarizing every Incident inserted
        and every group skipped.

    Raises:
        IncidentBuilderError: If querying MongoDB or persisting
            incidents fails at the infrastructure level.
    """
    settings = get_settings()
    window_minutes = settings.incident_window_minutes

    logger.info(
        "Starting incident building run",
        extra={"window_minutes": window_minutes},
    )

    result = IncidentBuilderResult()

    anomalies = await _fetch_unassigned_anomalies()
    if not anomalies:
        logger.info("No unassigned anomalous events found; nothing to build")
        return result

    event_windows = await _resolve_anomaly_event_windows(
        anomalies
    )

    logger.info(
        "Resolved anomaly event windows",
        extra={
            "anomaly_count": len(anomalies),
            "resolved_count": len(event_windows),
        },
    )

    grouped = _group_by_host_and_window(
        anomalies,
        event_windows,
        window_minutes,
    )

    logger.info(
        "Grouped anomalies into host/window buckets",
        extra={"group_count": len(grouped)},
    )

    incidents: List[Incident] = []

    for (host, window_start), group_anomalies in grouped.items():
        try:
            incident = _build_incident(
                host,
                group_anomalies,
                event_windows,
            )
            severity = compute_incident_severity(group_anomalies)

            logger.info(
                "Built incident",
                extra={
                    "host": host,
                    "window_start": window_start.isoformat(),
                    "anomaly_count": len(group_anomalies),
                    "severity": severity.value,
                    "start_time": incident.start_time.isoformat(),
                    "end_time": incident.end_time.isoformat(),
                },
            )
            incidents.append(incident)
        except (ValueError, Exception) as exc:  # noqa: BLE001 - isolate one bad group
            logger.exception(
                "Failed to build incident for host/window group",
                extra={
                    "host": host,
                    "window_start": window_start.isoformat(),
                    "anomaly_count": len(group_anomalies),
                },
            )
            result.skipped_groups.append(
                {
                    "host": host,
                    "window_start": window_start.isoformat(),
                    "anomaly_count": len(group_anomalies),
                    "reason": str(exc),
                }
            )

    inserted_ids = await _insert_incidents(incidents)
    result.inserted_ids.extend(inserted_ids)

    logger.info(
        "Completed incident building run",
        extra={
            "incidents_created": result.incidents_created,
            "groups_skipped": len(result.skipped_groups),
        },
    )
    return result
